{
  "title": "DC-09 Receiver",
  "uid": "dc09-receiver",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(dc09_messages_received_total, pod)",
        "label": "Pod",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0
      },
      {
        "name": "transport",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(dc09_connections_total, transport)",
        "label": "Transport",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0
      },
      {
        "name": "account",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(dc09_messages_received_total, account)",
        "label": "Account",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(dc09_active_connections)",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Messages Received",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(dc09_messages_received_total{pod=~\"$pod\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ingest Rate (msg/s)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dc09_messages_received_total{pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "msg/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Connections Accepted",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(dc09_connections_total{transport=~\"$transport\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Messages Failed",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(dc09_messages_failed_total)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Heartbeats Received",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "light-blue"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(dc09_heartbeat_received_total{account=~\"$account\"})",
          "legendFormat": "heartbeats"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Connections",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active Connections Over Time",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (dc09_active_connections{pod=~\"$pod\"})",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Connection Acceptance Rate per Transport",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (transport) (rate(dc09_connections_total{transport=~\"$transport\"}[$__rate_interval]))",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Messages",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Message Rate — All Pods Combined",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dc09_messages_received_total{pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Message Rate per Pod",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(dc09_messages_received_total{pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Message Rate per Account",
      "gridPos": {
        "x": 12,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (account) (rate(dc09_messages_received_total{pod=~\"$pod\", account=~\"$account\"}[$__rate_interval]))",
          "legendFormat": "{{account}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Failures",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Failure Rate by Reason",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(dc09_messages_failed_total[$__rate_interval]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Failure Rate by Transport",
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (transport) (rate(dc09_messages_failed_total{transport=~\"$transport\"}[$__rate_interval]))",
          "legendFormat": "{{transport}}"
        }
      ]
    },
    {
      "id": 33,
      "type": "table",
      "title": "Failed Message Totals by Transport & Reason",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Failures",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-background-solid"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "transport"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "auto"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "reason"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "auto"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "transport": "Transport",
              "reason": "Reason",
              "Value": "Failures"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sort_desc(sum by (transport, reason) (dc09_messages_failed_total{transport=~\"$transport\"}))",
          "legendFormat": "{{transport}} / {{reason}}",
          "instant": true
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Heartbeats & Account Health",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Heartbeat Rate per Account",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (account) (rate(dc09_heartbeat_received_total{account=~\"$account\"}[$__rate_interval]))",
          "legendFormat": "{{account}}"
        }
      ]
    },
    {
      "id": 42,
      "type": "bargauge",
      "title": "Seconds Since Last Message per Account",
      "description": "Time elapsed since the last DC-09 message was received. Green < 60 s, yellow < 5 min, red ≥ 5 min.",
      "gridPos": {
        "x": 14,
        "y": 46,
        "w": 10,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "time() - max by (account) (dc09_last_message_timestamp_seconds{account=~\"$account\"})",
          "legendFormat": "{{account}}",
          "instant": true
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Message Size Distribution",
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Message Size Percentiles (P50 / P90 / P99) per Transport",
      "gridPos": {
        "x": 0,
        "y": 55,
        "w": 14,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, transport) (rate(dc09_message_size_bytes_bucket{transport=~\"$transport\"}[$__rate_interval])))",
          "legendFormat": "p50 {{transport}}"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le, transport) (rate(dc09_message_size_bytes_bucket{transport=~\"$transport\"}[$__rate_interval])))",
          "legendFormat": "p90 {{transport}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, transport) (rate(dc09_message_size_bytes_bucket{transport=~\"$transport\"}[$__rate_interval])))",
          "legendFormat": "p99 {{transport}}"
        }
      ]
    },
    {
      "id": 52,
      "type": "bargauge",
      "title": "Average Message Size per Transport",
      "gridPos": {
        "x": 14,
        "y": 55,
        "w": 5,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (transport) (rate(dc09_message_size_bytes_sum{transport=~\"$transport\"}[$__rate_interval])) / sum by (transport) (rate(dc09_message_size_bytes_count{transport=~\"$transport\"}[$__rate_interval]))",
          "legendFormat": "{{transport}}",
          "instant": true
        }
      ]
    },
    {
      "id": 53,
      "type": "stat",
      "title": "Overall P99 Message Size",
      "gridPos": {
        "x": 19,
        "y": 55,
        "w": 5,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 512
              },
              {
                "color": "red",
                "value": 1024
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(dc09_message_size_bytes_bucket{transport=~\"$transport\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
